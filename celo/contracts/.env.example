# Deployer private key
PRIVATE_KEY=0x...

# cUSD token address
# Alfajores testnet: 0x874069Fa1Eb16D44d622F2e0Ca25eeA172369bC1
# Celo mainnet:      0x765DE816845861e75A25fCA122bb6898B8B1282a
